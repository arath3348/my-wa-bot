const { default: makeWASocket, useMultiFileAuthState, DisconnectReason, Browsers } = require('@whiskeysockets/baileys');
const { GoogleGenerativeAI } = require('@google/generative-ai');
const qrcode = require('qrcode-terminal');
const QRCode = require('qrcode');
const http = require('http');
const pino = require('pino');
const fs = require('fs');
const path = require('path');

const GEMINI_API_KEY = process.env.GEMINI_API_KEY;
const genAI = new GoogleGenerativeAI(GEMINI_API_KEY);

// =====================================
// QR HTTP SERVER
// =====================================
let currentQR = null;
let botStatus = 'Starting...';

const server = http.createServer(async (req, res) => {
  res.setHeader('Access-Control-Allow-Origin', '*');

  if (req.url === '/qr') {
    if (!currentQR) {
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><meta charset="utf-8">
        <meta http-equiv="refresh" content="3">
        <title>WA Bot QR</title></head>
        <body style="background:#111;color:#0f0;font-family:monospace;text-align:center;padding:50px">
        <h2>⏳ ${botStatus}</h2>
        <p>QR generate වෙනකන් wait කරන්න...</p>
        <p style="color:#888">Auto refresh වෙනවා...</p>
        </body></html>`);
      return;
    }
    try {
      const qrImageUrl = await QRCode.toDataURL(currentQR, { width: 300, margin: 2 });
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><meta charset="utf-8">
        <meta http-equiv="refresh" content="25">
        <title>WA Bot QR</title></head>
        <body style="background:#111;color:#0f0;font-family:monospace;text-align:center;padding:30px">
        <h2>📱 WhatsApp QR Scan කරන්න</h2>
        <p>WhatsApp → ⋮ → Linked Devices → Link a Device</p>
        <img src="${qrImageUrl}" style="border:5px solid #0f0;border-radius:10px"/>
        <p>Status: <b>${botStatus}</b></p>
        <p style="color:#888">QR 25s වල expire වෙනවා - auto refresh වෙනවා</p>
        </body></html>`);
    } catch (e) {
      res.writeHead(500);
      res.end('Error: ' + e.message);
    }
  } else {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(`<!DOCTYPE html><html><head><meta charset="utf-8">
      <title>WA Bot</title></head>
      <body style="background:#111;color:#0f0;font-family:monospace;text-align:center;padding:50px">
      <h1>🤖 WhatsApp AI Bot</h1>
      <p>Status: <b>${botStatus}</b></p>
      <br>
      <a href="/qr" style="background:#0f0;color:#000;padding:15px 30px;text-decoration:none;border-radius:8px;font-size:18px">
        📱 QR Scan කරන්න
      </a>
      </body></html>`);
  }
});

const PORT = process.env.PORT || 8080;
server.listen(PORT, '0.0.0.0', () => {
  console.log(`✅ HTTP Server started on port ${PORT}`);
});

// =====================================
// CONTACT PERSONAS
// =====================================
const contactPersonas = {};
// ✅ Add contacts like this:
// contactPersonas['94771234567@s.whatsapp.net'] = {
//   name: 'Kamal',
//   style: 'My best friend. Talks casually in Sinhala. Uses machan, malli.',
// };

// =====================================
// MY CHAT STYLE
// =====================================
const MY_CHAT_STYLE = `
You are impersonating a Sri Lankan phone owner. Follow their messaging style strictly:
- Uses Sinhala and English mixed (Singlish)
- Very short messages, 1-2 lines max
- Common words: "hm", "ok", "aney", "ahh", "machan", "thamai", "ne", "da", "ow"
- Sometimes uses emojis: 😂 🙈 ❤️ 👍 😅
- Casual tone, never formal
- Replies feel natural and human
Example messages:
"hm ok machan"
"aney danne na 😂"
"ahh ok thamai"
"sry late reply una"
"hmm niyamai"
"ow ow therenawa"
`;

// =====================================
// TEMP MEMORY (session only)
// =====================================
const tempMemory = {};

// =====================================
// GEMINI REPLY
// =====================================
async function getAIReply(contactJid, incomingMessage, contactName) {
  const persona = contactPersonas[contactJid] || {
    name: contactName,
    style: 'Reply naturally and friendly like a normal Sri Lankan person.',
  };

  if (!tempMemory[contactJid]) tempMemory[contactJid] = [];
  const memory = tempMemory[contactJid];

  memory.push({ role: 'user', content: incomingMessage });
  if (memory.length > 12) memory.shift();

  const memoryContext = memory
    .map(m => `${m.role === 'user' ? contactName : 'Me'}: ${m.content}`)
    .join('\n');

  const prompt = `${MY_CHAT_STYLE}

Contact: ${persona.name}
Style: ${persona.style}

Recent chat:
${memoryContext}

Latest message from ${persona.name}: "${incomingMessage}"

Reply as the phone owner. Short, natural, human-like.
Output ONLY the reply. No quotes, no explanation.`;

  try {
    const model = genAI.getGenerativeModel({ model: 'gemini-1.5-flash' });
    const result = await model.generateContent(prompt);
    const reply = result.response.text().trim().replace(/^["']|["']$/g, '');
    memory.push({ role: 'bot', content: reply });
    return reply;
  } catch (err) {
    console.error('Gemini error:', err.message);
    return 'hm 👍';
  }
}

// =====================================
// STICKER
// =====================================
async function sendRandomSticker(sock, jid) {
  const stickerDir = './stickers';
  if (!fs.existsSync(stickerDir)) return false;
  const files = fs.readdirSync(stickerDir).filter(f => f.endsWith('.webp'));
  if (!files.length) return false;
  const buf = fs.readFileSync(path.join(stickerDir, files[Math.floor(Math.random() * files.length)]));
  await sock.sendMessage(jid, { sticker: buf });
  return true;
}

// =====================================
// BOT MAIN
// =====================================
let retryCount = 0;

async function startBot() {
  const { state, saveCreds } = await useMultiFileAuthState('./auth_info');

  const sock = makeWASocket({
    auth: state,
    logger: pino({ level: 'silent' }),
    browser: Browsers.appropriate('Chrome'),  // ✅ 405 error fix
    connectTimeoutMs: 60000,
    retryRequestDelayMs: 2000,
    maxMsgRetryCount: 3,
    syncFullHistory: false,
  });

  sock.ev.on('creds.update', saveCreds);

  sock.ev.on('connection.update', ({ connection, lastDisconnect, qr }) => {
    if (qr) {
      currentQR = qr;
      botStatus = 'QR Ready - Scan Now!';
      retryCount = 0;
      console.log('\n📱 QR Ready! /qr page open කරන්න\n');
      qrcode.generate(qr, { small: true });
    }

    if (connection === 'close') {
      currentQR = null;
      const statusCode = lastDisconnect?.error?.output?.statusCode;
      console.log(`❌ Disconnected - Code: ${statusCode}`);

      if (statusCode === DisconnectReason.loggedOut) {
        botStatus = 'Logged out! auth_info delete කරලා redeploy කරන්න.';
        console.log('🚫 Logged out - reconnect නෑ');
        return;
      }

      retryCount++;
      const delay = Math.min(retryCount * 3000, 30000);
      botStatus = `Reconnecting... (${retryCount})`;
      console.log(`🔄 Reconnecting in ${delay / 1000}s...`);
      setTimeout(() => startBot(), delay);
    }

    if (connection === 'open') {
      currentQR = null;
      retryCount = 0;
      botStatus = '✅ Connected & Running!';
      console.log('✅ WhatsApp Bot Connected!');
    }
  });

  sock.ev.on('messages.upsert', async ({ messages, type }) => {
    if (type !== 'notify') return;

    for (const msg of messages) {
      if (msg.key.fromMe) continue;
      if (msg.key.remoteJid === 'status@broadcast') continue;

      const jid = msg.key.remoteJid;
      const senderName = msg.pushName || 'Friend';
      const text = msg.message?.conversation
        || msg.message?.extendedTextMessage?.text
        || '';

      if (!text) continue;

      console.log(`📩 [${senderName}]: ${text}`);

      // 10% chance sticker
      if (Math.random() < 0.1) {
        const sent = await sendRandomSticker(sock, jid);
        if (sent) { console.log('🎭 Sticker sent'); continue; }
      }

      const reply = await getAIReply(jid, text, senderName);
      console.log(`🤖 Reply: ${reply}`);

      // Human-like typing delay
      await new Promise(r => setTimeout(r, 1000 + Math.random() * 2000));
      await sock.sendMessage(jid, { text: reply }, { quoted: msg });
    }
  });
}

startBot();
